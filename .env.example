# ─── Client build-time (VITE_* prefix — exposed to browser bundle) ───
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_SENTRY_DSN=
VITE_POSTHOG_KEY=
VITE_WTCS_GUILD_ID=         # WT esports Discord server ID (client-side guild membership check)
# Optional Sentry release tag. Re-exported in netlify.toml build command from $COMMIT_REF (setting this literally in Netlify UI does NOT work — no shell expansion).
VITE_COMMIT_SHA=

# ─── Build-time only (NO VITE_ prefix — build runner / CI only, NEVER shipped to browser) ───
# Used by @sentry/vite-plugin during `npm run build` to upload sourcemaps:
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ─── Supabase Edge Function runtime (set via `supabase secrets set`, NOT .env) ───
# CLOSE_SWEEPER_SECRET=      # gates close-expired-polls cron endpoint
# UPSTASH_REDIS_REST_URL=         # rate limiter connection
# UPSTASH_REDIS_REST_TOKEN=       # rate limiter auth
# DISCORD_GUILD_ID=          # WT esports Discord server ID (guild check)

# ─── GitHub Actions repo secrets (set in GitHub repo Settings → Secrets, NOT .env) ───
# SUPABASE_ACCESS_TOKEN=     # for `supabase functions deploy`
# SUPABASE_PROJECT_REF=      # project linker for CLI
# SUPABASE_URL=              # full https://<ref>.supabase.co (cron base URL)
# SUPABASE_ANON_KEY=         # HIGH #3 — required by cron-sweep.yml for the Authorization: Bearer header
#                            # (Supabase EF gateway has verify_jwt=true by default)
# CLOSE_SWEEPER_SECRET=      # same value as the Supabase secret above
